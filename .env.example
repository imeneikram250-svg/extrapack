# ==========================================
# EXTRA PACK - Variables d'environnement
# ==========================================
# Copiez ce fichier en .env.local et remplissez les valeurs

# --- FIREBASE ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# --- GOOGLE SHEETS API ---
# Service Account credentials (JSON key file)
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Google Sheets IDs (found in the URL: /spreadsheets/d/SHEET_ID/edit)
PRODUCTS_SHEET_ID=your_products_sheet_id
DELIVERY_SHEET_ID=your_delivery_sheet_id
ORDERS_SHEET_ID=your_orders_sheet_id

# --- ADMIN ---
ADMIN_PASSWORD=your_secure_admin_password_here

# --- SITE ---
NEXT_PUBLIC_SITE_URL=https://www.extrapack.dz
NEXT_PUBLIC_WHATSAPP_NUMBER=213XXXXXXXXX
